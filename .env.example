# ── Database ──────────────────────────────────────────────────────────────────
# Prisma connection-pooling URL (e.g. Supabase Transaction Pooler / PgBouncer)
DATABASE_URL=

# Direct (non-pooled) URL — used by Prisma migrations
DIRECT_URL=

# Per-serverless-instance Prisma pg-adapter pool size.
# Recommended start: 5 for normal Vercel traffic, 1 for conservative A/B tests.
# Keep total open connections roughly below your Supabase pool size:
#   max concurrent Vercel instances × DATABASE_POOL_MAX <= Supabase pool size
DATABASE_POOL_MAX=5

# Production distributed rate limiting. When both are set, login failures and
# sensitive mutation routes share counters across Vercel instances. Do not use this Redis instance
# as a general ERP data cache without a separately measured/approved design.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel Marketplace's Upstash integration provides these standard aliases.
# Use either this complete pair or the complete UPSTASH_* pair above, not a
# mixture. The application prefers a complete UPSTASH_* pair when both exist.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
# NextAuth v5 reads AUTH_SECRET and falls back to NEXTAUTH_SECRET, so either
# works. Set NEXTAUTH_SECRET (below); AUTH_SECRET is an optional alias.
NEXTAUTH_SECRET=
# AUTH_SECRET=

# Full public URL of your deployment (no trailing slash). Local: http://localhost:3000
NEXTAUTH_URL=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Arbitrary secret sent in the X-Telegram-Bot-Api-Secret-Token header
# to validate that webhook calls originate from Telegram.
# Generate with:  openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ── Supabase Storage (passport & device image uploads) ───────────────────────
# Required only if you use image uploads; the private bucket auto-creates on
# first upload. Without these, upload endpoints return 500 but the rest runs.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRIVATE_BUCKET=oryx-private
# SUPABASE_ANON_KEY is not used by the app (kept for reference only).
# SUPABASE_ANON_KEY=

# Customer passport identifier privacy. Keep these two independent and rotate
# only through an approved key-version migration (never copy one into both).
# Generate each with: openssl rand -base64 48
CUSTOMER_PII_ENCRYPTION_KEY=
CUSTOMER_PII_SEARCH_KEY=

# ── Cron / internal API ───────────────────────────────────────────────────────
# Bearer token checked by GET /api/cron/reminders and POST /api/telegram/send.
# The route fails closed (503) without this secret; call it with
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
# Optional: a separate credential for app-owned internal calls. If both are
# configured, routes accept each independently; outbound app calls prefer this.
# INTERNAL_API_SECRET=

# ── Super admin seed (scripts/seed-super-admin.mjs) ───────────────────────────
# Idempotent: re-running creates/updates the configured admin logins. Password is
# REQUIRED and never defaulted. (SUPER_ADMIN_* are still accepted as fallbacks.)
SEED_SUPER_ADMIN_LOGIN=oryx_abdulloh
SEED_SUPER_ADMIN_NAME=Abdulloh
SEED_SUPER_ADMIN_2_LOGIN=wxusan
SEED_SUPER_ADMIN_2_NAME=Xusan
SEED_SUPER_ADMIN_PASSWORD=
