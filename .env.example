# ── Database ──────────────────────────────────────────────────────────────────
# Prisma connection-pooling URL (e.g. Supabase Pooler / PgBouncer)
DATABASE_URL=

# Direct (non-pooled) URL — used by Prisma migrations
DIRECT_URL=

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=

# Full public URL of your deployment (no trailing slash)
NEXTAUTH_URL=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Arbitrary secret sent in the X-Telegram-Bot-Api-Secret-Token header
# to validate that webhook calls originate from Telegram.
# Generate with:  openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRIVATE_BUCKET=oryx-private

# ── Cron (optional) ───────────────────────────────────────────────────────────
# Bearer token checked by GET /api/cron/reminders when called by external
# cron services (leave empty to rely on Vercel Cron authentication).
CRON_SECRET=

# Development seed defaults
SUPER_ADMIN_EMAIL=admin@oryx.local
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PASSWORD=Admin12345!
