// Oryx Tech ERP — Prisma Schema
// SaaS platform for Malika Bazar tech shops

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum SuperAdminRole {
  SUPER_ADMIN
}

enum ShopStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum DeviceStatus {
  IN_STOCK
  SOLD_CASH
  SOLD_NASIYA
  RESERVED
  RETURNED
  DELETED
}

enum NasiyaStatus {
  ACTIVE
  COMPLETED
  OVERDUE
  CANCELLED
}

enum NasiyaScheduleStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  DEFERRED
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

enum ActorType {
  SUPER_ADMIN
  SHOP_ADMIN
}

enum OpsLevel {
  INFO
  WARN
  ERROR
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}

// ---------------------------------------------------------------------------
// SuperAdmin
// ---------------------------------------------------------------------------

model SuperAdmin {
  id                 String         @id @default(cuid())
  name               String
  login              String         @unique
  telegramId         String?
  telegramVerifiedAt DateTime?
  passwordHash       String
  sessionVersion     Int            @default(1)
  role               SuperAdminRole @default(SUPER_ADMIN)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  // Relations
  shopsCreated Shop[]        @relation("ShopCreatedBy")
  shopPayments ShopPayment[]

  @@index([telegramId])
}

// ---------------------------------------------------------------------------
// Shop
// ---------------------------------------------------------------------------

model Shop {
  id              String     @id @default(cuid())
  name            String
  ownerName       String
  ownerPhone      String
  shopNumber      String
  address         String
  note            String?
  status          ShopStatus @default(ACTIVE)
  subscriptionDue DateTime
  telegramGroupId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
  deletedBy       String?
  deleteNote      String?

  // FK
  createdById String
  createdBy   SuperAdmin @relation("ShopCreatedBy", fields: [createdById], references: [id])

  // Relations
  payments      ShopPayment[]
  admins        ShopAdmin[]
  devices       Device[]
  deviceReturns DeviceReturn[]
  suppliers     Supplier[]
  sales         Sale[]
  customers     Customer[]
  nasiya        Nasiya[]
  notifications Notification[]
  logs          Log[]

  @@index([status])
}

// ---------------------------------------------------------------------------
// ShopPayment
// ---------------------------------------------------------------------------

model ShopPayment {
  id            String        @id @default(cuid())
  shopId        String
  amount        Decimal       @db.Decimal(12, 2)
  months        Int
  paymentMethod PaymentMethod
  note          String?
  paidAt        DateTime      @default(now())
  deletedAt     DateTime?
  deletedBy     String?
  deleteNote    String?

  // FK
  recordedById String
  recordedBy   SuperAdmin @relation(fields: [recordedById], references: [id])
  shop         Shop       @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([paidAt])
}

// ---------------------------------------------------------------------------
// ShopAdmin
// ---------------------------------------------------------------------------

model ShopAdmin {
  id                 String    @id @default(cuid())
  shopId             String
  name               String
  phone              String
  login              String
  telegramId         String?
  telegramVerifiedAt DateTime?
  passwordHash       String
  passwordChangedAt  DateTime  @default(now())
  sessionVersion     Int       @default(1)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  deletedAt          DateTime?
  deletedBy          String?
  deleteNote         String?

  // Relations
  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([login])
  @@index([shopId])
  @@index([shopId, phone])
  @@index([telegramId])
}

// ---------------------------------------------------------------------------
// Supplier
// ---------------------------------------------------------------------------

model Supplier {
  id         String    @id @default(cuid())
  shopId     String
  name       String
  phone      String
  note       String?
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  deletedBy  String?
  deleteNote String?

  // Relations
  shop    Shop     @relation(fields: [shopId], references: [id])
  devices Device[]

  @@index([shopId])
}

// ---------------------------------------------------------------------------
// Device
// ---------------------------------------------------------------------------

model Device {
  id            String       @id @default(cuid())
  shopId        String
  model         String
  color         String?
  storage       String?
  batteryHealth Int?
  purchasePrice Decimal      @db.Decimal(12, 2)
  imei          String
  supplierId    String?
  supplierPhone String?
  imageUrls     String[]
  status        DeviceStatus @default(IN_STOCK)
  addedBy       String
  note          String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  deletedBy     String?
  deleteNote    String?

  // Relations
  shop     Shop           @relation(fields: [shopId], references: [id])
  supplier Supplier?      @relation(fields: [supplierId], references: [id])
  sales    Sale[]
  nasiya   Nasiya[]
  returns  DeviceReturn[]

  // ACTIVE-ONLY IMEI UNIQUENESS is enforced by a raw-SQL PARTIAL UNIQUE index
  // `Device_shopId_imei_active_key ... WHERE "deletedAt" IS NULL` created in
  // prisma/migrations/202607020002_integrity_return_ledger. Prisma cannot
  // express partial uniques, so this is only a plain index here. DO NOT run
  // `prisma db push` or `prisma migrate dev` against a real DB — they would
  // treat the partial unique as drift and drop it. Use `migrate deploy` only.
  @@index([shopId, imei])
  @@index([shopId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Customer
// ---------------------------------------------------------------------------

model Customer {
  id               String    @id @default(cuid())
  shopId           String
  name             String
  phone            String
  normalizedPhone  String?
  passportPhotoUrl String?
  note             String?
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
  deletedBy        String?
  deleteNote       String?

  // Relations
  shop   Shop     @relation(fields: [shopId], references: [id])
  sales  Sale[]
  nasiya Nasiya[]

  // ACTIVE-ONLY CUSTOMER PHONE UNIQUENESS (per shop) is enforced by a raw-SQL
  // PARTIAL UNIQUE index `Customer_shopId_normalizedPhone_active_key ... WHERE
  // "deletedAt" IS NULL AND "normalizedPhone" IS NOT NULL` created in
  // prisma/migrations/202607020002_integrity_return_ledger. Prisma cannot
  // express partial uniques, so this is only a plain index here. DO NOT run
  // `prisma db push` / `prisma migrate dev` — they would drop it. Use
  // `migrate deploy` only.
  @@index([shopId])
  @@index([shopId, normalizedPhone])
}

// ---------------------------------------------------------------------------
// Sale
// ---------------------------------------------------------------------------

model Sale {
  id              String        @id @default(cuid())
  shopId          String
  deviceId        String
  customerId      String
  salePrice       Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  paidFully       Boolean       @default(true)
  amountPaid      Decimal       @db.Decimal(12, 2)
  remainingAmount Decimal       @default(0) @db.Decimal(12, 2)
  dueDate         DateTime?
  reminderEnabled Boolean       @default(false)
  note            String?
  createdAt       DateTime      @default(now())
  createdBy       String
  deletedAt       DateTime?
  deletedBy       String?
  deleteNote      String?

  // Relations
  shop     Shop           @relation(fields: [shopId], references: [id])
  device   Device         @relation(fields: [deviceId], references: [id])
  customer Customer       @relation(fields: [customerId], references: [id])
  payments SalePayment[]
  returns  DeviceReturn[]

  @@index([shopId])
  @@index([customerId])
  @@index([deviceId])
  @@index([shopId, paidFully, dueDate])
  // Cross-shop cron scan (overdue sale reminders): filters by paidFully + due
  // date with no shopId, so a shopId-leading index cannot serve it.
  @@index([paidFully, dueDate])
}

// ---------------------------------------------------------------------------
// SalePayment
// ---------------------------------------------------------------------------

model SalePayment {
  id             String        @id @default(cuid())
  saleId         String
  shopId         String
  amount         Decimal       @db.Decimal(12, 2)
  paymentMethod  PaymentMethod
  paidAt         DateTime      @default(now())
  note           String?
  idempotencyKey String?
  createdBy      String
  createdAt      DateTime      @default(now())
  deletedAt      DateTime?
  deletedBy      String?
  deleteNote     String?

  // Relations
  sale Sale @relation(fields: [saleId], references: [id])

  @@unique([shopId, idempotencyKey])
  @@index([saleId])
  @@index([shopId])
  @@index([paidAt])
}

// ---------------------------------------------------------------------------
// Nasiya (Instalment plan)
// ---------------------------------------------------------------------------

model Nasiya {
  id                  String       @id @default(cuid())
  shopId              String
  deviceId            String
  customerId          String
  // Original agreed device sale price before down payment and nasiya interest.
  totalAmount         Decimal      @db.Decimal(12, 2)
  downPayment         Decimal      @db.Decimal(12, 2)
  // Debt before interest: totalAmount - downPayment.
  baseRemainingAmount Decimal      @default(0) @db.Decimal(12, 2)
  interestPercent     Decimal      @default(0) @db.Decimal(6, 2)
  interestAmount      Decimal      @default(0) @db.Decimal(12, 2)
  finalNasiyaAmount   Decimal      @default(0) @db.Decimal(12, 2)
  remainingAmount     Decimal      @db.Decimal(12, 2)
  months              Int
  monthlyPayment      Decimal      @db.Decimal(12, 2)
  startDate           DateTime
  status              NasiyaStatus @default(ACTIVE)
  reminderEnabled     Boolean      @default(true)
  note                String?
  createdAt           DateTime     @default(now())
  createdBy           String
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?
  deletedBy           String?
  deleteNote          String?

  // Relations
  shop      Shop             @relation(fields: [shopId], references: [id])
  device    Device           @relation(fields: [deviceId], references: [id])
  customer  Customer         @relation(fields: [customerId], references: [id])
  schedules NasiyaSchedule[]
  payments  NasiyaPayment[]
  returns   DeviceReturn[]

  @@index([shopId])
  @@index([status])
  @@index([deviceId])
  @@index([customerId])
}

// ---------------------------------------------------------------------------
// NasiyaSchedule
// ---------------------------------------------------------------------------

model NasiyaSchedule {
  id             String               @id @default(cuid())
  nasiyaId       String
  shopId         String
  monthNumber    Int
  dueDate        DateTime
  expectedAmount Decimal              @db.Decimal(12, 2)
  paidAmount     Decimal              @default(0) @db.Decimal(12, 2)
  status         NasiyaScheduleStatus @default(PENDING)
  paidAt         DateTime?
  paymentMethod  PaymentMethod?
  delayedUntil   DateTime?
  deferredToNext Boolean              @default(false)
  note           String?
  createdAt      DateTime             @default(now())

  // Relations
  nasiya   Nasiya          @relation(fields: [nasiyaId], references: [id], onDelete: Cascade)
  payments NasiyaPayment[]

  @@index([nasiyaId])
  @@index([shopId])
  @@index([status])
  @@index([shopId, status, dueDate])
  // Cross-shop cron scan (reminders/overdue): filters by status + due date with
  // no shopId, so a shopId-leading index cannot serve it.
  @@index([status, dueDate])
}

// ---------------------------------------------------------------------------
// NasiyaPayment
// ---------------------------------------------------------------------------

model NasiyaPayment {
  id               String         @id @default(cuid())
  nasiyaId         String
  nasiyaScheduleId String?
  shopId           String
  amount           Decimal        @db.Decimal(12, 2)
  paymentMethod    PaymentMethod?
  paidAt           DateTime       @default(now())
  note             String?
  idempotencyKey   String?
  createdBy        String
  createdAt        DateTime       @default(now())
  deletedAt        DateTime?
  deletedBy        String?
  deleteNote       String?

  // Relations
  nasiya   Nasiya          @relation(fields: [nasiyaId], references: [id])
  schedule NasiyaSchedule? @relation(fields: [nasiyaScheduleId], references: [id])

  @@unique([shopId, idempotencyKey])
  @@index([nasiyaId])
  @@index([nasiyaScheduleId])
  @@index([shopId])
  @@index([paidAt])
}

// ---------------------------------------------------------------------------
// DeviceReturn
// ---------------------------------------------------------------------------

model DeviceReturn {
  id           String         @id @default(cuid())
  shopId       String
  deviceId     String
  saleId       String?
  nasiyaId     String?
  refundAmount Decimal        @default(0) @db.Decimal(12, 2)
  refundMethod PaymentMethod?
  note         String
  createdBy    String
  createdAt    DateTime       @default(now())

  // Relations
  shop   Shop    @relation(fields: [shopId], references: [id])
  device Device  @relation(fields: [deviceId], references: [id])
  sale   Sale?   @relation(fields: [saleId], references: [id])
  nasiya Nasiya? @relation(fields: [nasiyaId], references: [id])

  @@index([shopId])
  @@index([deviceId])
  @@index([saleId])
  @@index([nasiyaId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Notification
// ---------------------------------------------------------------------------

model Notification {
  id            String             @id @default(cuid())
  shopId        String
  dedupeKey     String?            @unique
  type          String
  message       String
  telegramId    String
  status        NotificationStatus @default(PENDING)
  scheduledAt   DateTime
  sentAt        DateTime?
  attemptCount  Int                @default(0)
  lastAttemptAt DateTime?
  nextAttemptAt DateTime?
  lastError     String?
  relatedId     String?
  relatedType   String?
  createdAt     DateTime           @default(now())

  // Relations
  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([status])
  @@index([scheduledAt])
  @@index([nextAttemptAt])
  @@index([status, scheduledAt, nextAttemptAt])
}

// ---------------------------------------------------------------------------
// Log
// ---------------------------------------------------------------------------

model Log {
  id         String    @id @default(cuid())
  shopId     String?
  actorId    String
  actorType  ActorType
  action     String
  targetType String
  targetId   String
  oldValue   Json?
  newValue   Json?
  note       String?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  // Relations (shopId nullable — null means super admin action)
  shop Shop? @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([shopId, createdAt])
}

// ---------------------------------------------------------------------------
// OpsEvent — system health / job / failure telemetry.
//
// This is NOT the business audit `Log` (user/admin actions). OpsEvent records
// infrastructure signals: cron runs, notification processing outcomes, Telegram
// send/webhook failures, migration-guard blocks. `metadata` must stay small and
// MUST NOT contain secrets, full request bodies, or signed private URLs.
// ---------------------------------------------------------------------------

model OpsEvent {
  id         String    @id @default(cuid())
  level      OpsLevel  @default(INFO)
  event      String
  message    String
  shopId     String?
  actorId    String?
  actorType  ActorType?
  entityType String?
  entityId   String?
  status     String?
  errorCode  String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([level])
  @@index([event])
  @@index([createdAt])
  @@index([event, createdAt])
}
