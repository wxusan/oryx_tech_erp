// Oryx Tech ERP — Prisma Schema
// SaaS platform for Malika Bazar tech shops

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum SuperAdminRole {
  SUPER_ADMIN
}

enum ShopStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ShopOwnershipStatus {
  RESOLVED
  UNMATCHED
  AMBIGUOUS
}

enum ShopPaymentAllocationStatus {
  PACKAGE_ALLOCATED
  LEGACY_UNALLOCATED
}

enum DeviceStatus {
  IN_STOCK
  SOLD_CASH
  SOLD_DEBT
  SOLD_NASIYA
  RETURNED
  DELETED
}

enum NasiyaStatus {
  ACTIVE
  COMPLETED
  OVERDUE
  CANCELLED
}

enum NasiyaResolutionState {
  ACTIVE
  ARCHIVED
  WRITTEN_OFF
}

enum NasiyaResolutionEventType {
  ARCHIVE
  WRITE_OFF
  REOPEN
}

enum NasiyaScheduleStatus {
  PENDING
  PAID
  SETTLED
  PARTIAL
  OVERDUE
  DEFERRED
  CANCELLED
}

enum NasiyaSettlementMode {
  FULL_WITH_PROFIT
  WAIVE_REMAINING_PROFIT
}

// Whether historic payment-component facts can be used for monthly profit.
// PENDING/PARTIAL/UNRECONSTRUCTABLE rows are deliberately excluded from
// profit aggregates; cash receipts remain visible from the immutable payment
// rows even when their profit split cannot be proven.
enum AccountingReconstructionStatus {
  PENDING
  COMPLETE
  PARTIAL
  UNRECONSTRUCTABLE
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

enum ActorType {
  SUPER_ADMIN
  SHOP_ADMIN
}

enum AuthSessionPolicy {
  IDLE_10_MINUTES
  REMEMBERED_30_DAYS
}

enum OpsLevel {
  INFO
  WARN
  ERROR
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}

enum CurrencyCode {
  UZS
  USD
}

enum StorageUnit {
  GB
  TB
}

enum DeviceConditionCode {
  NEW
  USED
}

enum DeviceImeiSlot {
  PRIMARY
  SECONDARY
}

// ---------------------------------------------------------------------------
// SuperAdmin
// ---------------------------------------------------------------------------

model SuperAdmin {
  id                 String         @id @default(cuid())
  name               String
  login              String         @unique
  telegramId         String?
  telegramVerifiedAt DateTime?
  passwordHash       String
  sessionVersion     Int            @default(1)
  role               SuperAdminRole @default(SUPER_ADMIN)
  preferredCurrency  CurrencyCode   @default(UZS)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  // Relations
  shopsCreated           Shop[]               @relation("ShopCreatedBy")
  shopPayments           ShopPayment[]
  packageVersionsCreated ShopPackageVersion[] @relation("PackageVersionCreatedBy")
  ownershipsResolved     Shop[]               @relation("ShopOwnershipResolvedBy")

  @@index([telegramId])
}

// A single platform-wide reporting window. Resetting this boundary starts
// Super Admin subscription-revenue aggregates over without deleting the
// immutable ShopPayment receipts that remain available for audit and export.
model PlatformRevenueReportWindow {
  id                          String   @id
  subscriptionRevenueStartsAt DateTime
  createdAt                   DateTime @default(now())
}

// A single platform-wide acknowledgement boundary for the Super Admin
// operations console. It preserves OpsEvent/Notification history for audit
// while making the live health view show only issues raised after this point.
model OpsAlertState {
  id                  String   @id
  alertWindowStartsAt DateTime
  acknowledgedAt      DateTime
  acknowledgedById    String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Shop
// ---------------------------------------------------------------------------

model Shop {
  id                           String              @id @default(cuid())
  name                         String
  ownerName                    String
  ownerPhone                   String
  shopNumber                   String
  address                      String
  note                         String?
  status                       ShopStatus          @default(ACTIVE)
  subscriptionDue              DateTime
  telegramGroupId              String?
  telegramNotificationsEnabled Boolean             @default(true)
  preferredCurrency            CurrencyCode        @default(UZS)
  authorizationVersion         Int                 @default(1)
  billingAnchorDay             Int                 @default(1)
  ownerAdminId                 String?             @unique
  ownershipStatus              ShopOwnershipStatus @default(UNMATCHED)
  ownershipResolvedAt          DateTime?
  ownershipResolvedById        String?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  deletedAt                    DateTime?
  deletedBy                    String?
  deleteNote                   String?

  // FK
  createdById         String
  createdBy           SuperAdmin  @relation("ShopCreatedBy", fields: [createdById], references: [id])
  ownershipResolvedBy SuperAdmin? @relation("ShopOwnershipResolvedBy", fields: [ownershipResolvedById], references: [id])
  ownerAdmin          ShopAdmin?  @relation("ShopOwnerAdmin", fields: [ownerAdminId, id], references: [id, shopId])

  // Relations
  payments                    ShopPayment[]
  admins                      ShopAdmin[]                  @relation("ShopMembers")
  devices                     Device[]
  deviceReturns               DeviceReturn[]
  suppliers                   Supplier[]
  sales                       Sale[]
  customers                   Customer[]
  nasiya                      Nasiya[]
  notifications               Notification[]
  logs                        Log[]
  supplierPayables            SupplierPayable[]
  supplierPayablePayments     SupplierPayablePayment[]
  olibSotdimOperations        OlibSotdimOperation[]
  packageVersions             ShopPackageVersion[]
  telegramDisableTransitions  TelegramDisableTransition[]
  memberPermissions           ShopMemberPermission[]
  staffRoles                  ShopStaffRole[]
  staffRolePermissions        ShopStaffRolePermission[]
  nasiyaPaymentAllocations    NasiyaPaymentAllocation[]
  nasiyaSettlements           NasiyaSettlement[]
  nasiyaSettlementAllocations NasiyaSettlementAllocation[]
  returnProfitReversals       ReturnProfitReversal[]

  @@unique([ownerAdminId, id])
  @@index([status])
}

// ---------------------------------------------------------------------------
// ShopPayment
// ---------------------------------------------------------------------------

model ShopPayment {
  id                           String                         @id @default(cuid())
  shopId                       String
  amount                       Decimal                        @db.Decimal(12, 2)
  months                       Int
  paymentMethod                PaymentMethod
  note                         String?
  idempotencyKey               String?
  commandHash                  String?
  paidAt                       DateTime                       @default(now())
  deletedAt                    DateTime?
  deletedBy                    String?
  deleteNote                   String?
  allocationStatus             ShopPaymentAllocationStatus    @default(LEGACY_UNALLOCATED)
  currency                     CurrencyCode
  // Immutable reporting snapshots. Native `amount` + `currency` remain the
  // receipt source of truth; these two fields let Super Admin reports switch
  // currencies without revaluing historical cash at today's rate.
  exchangeRateAtPayment        Decimal?                       @db.Decimal(12, 4)
  amountUzsSnapshot            Decimal?                       @db.Decimal(12, 2)
  amountUsdSnapshot            Decimal?                       @db.Decimal(12, 2)
  currencyReconstructionStatus AccountingReconstructionStatus @default(PENDING)
  packageVersionId             String?
  packageMonthlyPriceSnapshot  Decimal?                       @db.Decimal(12, 2)
  servicePeriodStart           DateTime?                      @db.Date
  servicePeriodEnd             DateTime?                      @db.Date
  dueBefore                    DateTime?
  dueAfter                     DateTime?

  // FK
  recordedById   String
  recordedBy     SuperAdmin          @relation(fields: [recordedById], references: [id])
  shop           Shop                @relation(fields: [shopId], references: [id])
  packageVersion ShopPackageVersion? @relation(fields: [packageVersionId, shopId], references: [id, shopId])

  @@unique([shopId, idempotencyKey])
  @@index([shopId])
  @@index([packageVersionId, shopId])
  @@index([paidAt])
}

// ---------------------------------------------------------------------------
// CurrencyRate
// ---------------------------------------------------------------------------

model CurrencyRate {
  id            String       @id @default(cuid())
  baseCurrency  CurrencyCode
  quoteCurrency CurrencyCode
  rate          Decimal      @db.Decimal(12, 4)
  source        String       @default("CBU")
  fetchedAt     DateTime
  effectiveDate DateTime?
  createdAt     DateTime     @default(now())

  @@index([baseCurrency, quoteCurrency, fetchedAt])
  @@index([source, fetchedAt])
}

// ---------------------------------------------------------------------------
// ShopAdmin
// ---------------------------------------------------------------------------

model ShopAdmin {
  id                           String    @id @default(cuid())
  shopId                       String
  name                         String
  phone                        String
  login                        String
  telegramId                   String?
  telegramVerifiedAt           DateTime?
  passwordHash                 String
  passwordChangedAt            DateTime  @default(now())
  sessionVersion               Int       @default(1)
  permissionVersion            Int       @default(1)
  staffRoleId                  String?
  roleVersionApplied           Int?
  isActive                     Boolean   @default(true)
  legacyFullAccess             Boolean   @default(false)
  telegramNotificationsEnabled Boolean   @default(false)
  createdAt                    DateTime  @default(now())
  deletedAt                    DateTime?
  deletedBy                    String?
  deleteNote                   String?

  // Relations
  shop               Shop                   @relation("ShopMembers", fields: [shopId], references: [id])
  ownedShop          Shop?                  @relation("ShopOwnerAdmin")
  permissions        ShopMemberPermission[] @relation("PermissionMember")
  permissionsGranted ShopMemberPermission[] @relation("PermissionGrantedBy")
  notifications      Notification[]         @relation("NotificationRecipient")
  staffRole          ShopStaffRole?         @relation("StaffRoleMembers", fields: [staffRoleId, shopId], references: [id, shopId])

  @@unique([login])
  @@unique([id, shopId])
  @@index([shopId])
  @@index([shopId, staffRoleId])
  @@index([shopId, phone])
  @@index([telegramId])
}

// ---------------------------------------------------------------------------
// Expandable feature and permission catalogs. Stable string codes allow new
// commercial modules and staff capabilities without a PostgreSQL enum
// migration; application code still exposes a closed typed catalog.
// ---------------------------------------------------------------------------

model FeatureDefinition {
  code          String   @id
  nameUz        String
  descriptionUz String?
  billable      Boolean  @default(true)
  platformCore  Boolean  @default(false)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  packageFeatures ShopPackageFeature[]
  permissions     PermissionDefinition[]
}

model PermissionDefinition {
  code          String   @id
  nameUz        String
  descriptionUz String?
  featureCode   String?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberPermissions ShopMemberPermission[]
  rolePermissions   ShopStaffRolePermission[]
  feature           FeatureDefinition?        @relation(fields: [featureCode], references: [code])

  @@index([featureCode])
}

// One immutable version is a complete package snapshot. The active package is
// the latest version whose effectiveOn is not in the future.
model ShopPackageVersion {
  id                 String       @id @default(cuid())
  shopId             String
  effectiveOn        DateTime     @db.Date
  basePrice          Decimal      @db.Decimal(12, 2)
  currency           CurrencyCode @default(UZS)
  discountAmount     Decimal      @default(0) @db.Decimal(12, 2)
  pricingNeedsReview Boolean      @default(false)
  note               String
  createdById        String
  createdAt          DateTime     @default(now())

  shop                      Shop                       @relation(fields: [shopId], references: [id])
  createdBy                 SuperAdmin                 @relation("PackageVersionCreatedBy", fields: [createdById], references: [id])
  features                  ShopPackageFeature[]
  payments                  ShopPayment[]
  sessions                  AuthSession[]
  telegramDisableTransition TelegramDisableTransition?

  @@unique([id, shopId])
  @@unique([shopId, effectiveOn])
  @@index([shopId, effectiveOn(sort: Desc), createdAt(sort: Desc)])
}

// Every package snapshot that disables Telegram gets one durable transition.
// Future-dated transitions are processed at Tashkent midnight; processed rows
// remain as proof that an older verified identity was purged exactly once.
model TelegramDisableTransition {
  id               String    @id @default(cuid())
  packageVersionId String    @unique
  shopId           String
  effectiveOn      DateTime  @db.Date
  processedAt      DateTime?
  outcome          String?
  lastError        String?
  attemptCount     Int       @default(0)
  lastAttemptAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  shop           Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  packageVersion ShopPackageVersion @relation(fields: [packageVersionId, shopId], references: [id, shopId], onDelete: Cascade)

  @@unique([packageVersionId, shopId])
  @@index([processedAt, effectiveOn, id])
  @@index([shopId, processedAt, effectiveOn])
}

model ShopPackageFeature {
  id               String  @id @default(cuid())
  packageVersionId String
  featureCode      String
  enabled          Boolean
  recurringPrice   Decimal @default(0) @db.Decimal(12, 2)

  packageVersion ShopPackageVersion @relation(fields: [packageVersionId], references: [id])
  feature        FeatureDefinition  @relation(fields: [featureCode], references: [code])

  @@unique([packageVersionId, featureCode])
  @@index([featureCode])
}

model ShopMemberPermission {
  id             String   @id @default(cuid())
  shopId         String
  shopAdminId    String
  permissionCode String
  grantedAt      DateTime @default(now())
  grantedById    String

  shop       Shop                 @relation(fields: [shopId], references: [id])
  member     ShopAdmin            @relation("PermissionMember", fields: [shopAdminId, shopId], references: [id, shopId])
  grantedBy  ShopAdmin            @relation("PermissionGrantedBy", fields: [grantedById, shopId], references: [id, shopId])
  permission PermissionDefinition @relation(fields: [permissionCode], references: [code])

  @@unique([shopAdminId, permissionCode])
  @@index([shopId, permissionCode])
}

// Reusable, shop-scoped staff roles. Effective authorization is deliberately
// materialized into ShopMemberPermission so request-time RBAC stays join-free.
model ShopStaffRole {
  id             String   @id @default(cuid())
  shopId         String
  name           String
  normalizedName String
  description    String?
  kind           String   @default("CUSTOM")
  presetKey      String?
  isArchived     Boolean  @default(false)
  version        Int      @default(1)
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop        Shop                      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  permissions ShopStaffRolePermission[]
  members     ShopAdmin[]               @relation("StaffRoleMembers")

  @@unique([id, shopId])
  @@unique([shopId, presetKey])
  @@index([shopId, isArchived, createdAt])
  @@index([shopId, normalizedName])
}

model ShopStaffRolePermission {
  id             String   @id @default(cuid())
  shopId         String
  roleId         String
  permissionCode String
  createdAt      DateTime @default(now())

  shop       Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  role       ShopStaffRole        @relation(fields: [roleId, shopId], references: [id, shopId], onDelete: Cascade)
  permission PermissionDefinition @relation(fields: [permissionCode], references: [code])

  @@unique([roleId, permissionCode])
  @@index([shopId, permissionCode])
  @@index([shopId, roleId])
}

// ---------------------------------------------------------------------------
// Supplier
// ---------------------------------------------------------------------------

model Supplier {
  id         String    @id @default(cuid())
  shopId     String
  name       String
  phone      String
  note       String?
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  deletedBy  String?
  deleteNote String?

  // Relations
  shop     Shop              @relation(fields: [shopId], references: [id])
  devices  Device[]
  payables SupplierPayable[]

  @@unique([id, shopId])
  @@index([shopId])
}

// ---------------------------------------------------------------------------
// Device
// ---------------------------------------------------------------------------

model Device {
  id                             String               @id @default(cuid())
  shopId                         String
  model                          String
  color                          String?
  storage                        String?
  storageAmount                  Decimal?             @db.Decimal(10, 2)
  storageUnit                    StorageUnit?
  batteryHealth                  Int?
  purchasePrice                  Decimal              @db.Decimal(12, 2)
  // Native purchase-currency context, additive — `purchasePrice` above stays
  // exactly as-is (UZS compatibility snapshot, dual-written in lockstep).
  // See docs/currency-accounting-model.md. Pre-existing rows are backfilled
  // to UZS (never an invented historical currency/rate).
  purchaseCurrency               CurrencyCode         @default(UZS)
  purchaseInputAmount            Decimal              @default(0) @db.Decimal(12, 2)
  purchaseExchangeRateAtCreation Decimal?             @db.Decimal(12, 4)
  purchaseAmountUzsSnapshot      Decimal              @default(0) @db.Decimal(12, 2)
  imei                           String
  supplierId                     String?
  supplierPhone                  String?
  imageUrls                      String[]
  status                         DeviceStatus         @default(IN_STOCK)
  addedBy                        String
  note                           String?
  condition                      String?
  conditionCode                  DeviceConditionCode?
  // A device created only to carry an imported (pre-Oryx) nasiya. It is created
  // as SOLD_NASIYA (never IN_STOCK), so it never enters sellable inventory or
  // inventory-cost stats. Its purchasePrice is 0 (original cost unknown).
  isImported                     Boolean              @default(false)
  // "Olib-sotdim": sourced from another shop/person and sold to our customer in
  // the same operation. Created directly as SOLD_CASH (never IN_STOCK), so it
  // never becomes available for a later normal sale/nasiya and never enters
  // inventoryPurchaseCost (that stat only sums IN_STOCK devices).
  // purchasePrice IS real (what we paid the external supplier) — unlike
  // isImported, this does count toward this month's cost/profit normally.
  isExternalSourced              Boolean              @default(false)
  createdAt                      DateTime             @default(now())
  updatedAt                      DateTime             @updatedAt
  deletedAt                      DateTime?
  deletedBy                      String?
  deleteNote                     String?

  // Relations
  shop                Shop                 @relation(fields: [shopId], references: [id])
  supplier            Supplier?            @relation(fields: [supplierId], references: [id])
  sales               Sale[]
  nasiya              Nasiya[]
  returns             DeviceReturn[]
  supplierPayables    SupplierPayable[]
  olibSotdimOperation OlibSotdimOperation?
  imeis               DeviceImei[]

  @@unique([id, shopId])
  // ACTIVE-ONLY IMEI UNIQUENESS is enforced by a raw-SQL PARTIAL UNIQUE index
  // `Device_shopId_imei_active_key ... WHERE "deletedAt" IS NULL` created in
  // prisma/migrations/202607020002_integrity_return_ledger. Prisma cannot
  // express partial uniques, so this is only a plain index here. DO NOT run
  // `prisma db push` or `prisma migrate dev` against a real DB — they would
  // treat the partial unique as drift and drop it. Use `migrate deploy` only.
  @@index([shopId, imei])
  @@index([shopId])
  @@index([status])
}

model DeviceImei {
  id              String         @id @default(cuid())
  shopId          String
  deviceId        String
  slot            DeviceImeiSlot
  value           String
  normalizedValue String?
  isLegacy        Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  device Device @relation(fields: [deviceId, shopId], references: [id, shopId])

  @@index([deviceId, slot])
  @@index([shopId, normalizedValue])
}

// ---------------------------------------------------------------------------
// Customer
// ---------------------------------------------------------------------------

model Customer {
  id                            String    @id @default(cuid())
  shopId                        String
  name                          String
  phone                         String
  normalizedPhone               String?
  // Additional contact numbers beyond the primary `phone` — e.g. a relative's
  // or second personal number. Stored normalized (digits-only, `phone.ts`
  // convention) so search can match them the same way as the primary phone.
  // Additive, optional; existing customers default to an empty array.
  additionalPhones              String[]  @default([])
  passportPhotoUrl              String?
  // The full identifier is application-encrypted (AES-256-GCM). Exact search
  // uses a secret-scoped normalized HMAC; only the last four characters may
  // be returned by normal customer/profile DTOs. See customer-passport.ts.
  passportIdentifierCiphertext  String?
  passportIdentifierHash        String?
  passportIdentifierLast4       String?
  passportIdentifierKeyVersion  Int?
  note                          String?
  // Item 12 — optional admin override for the computed nasiya trust rating
  // (src/lib/nasiya-customer-trust.ts). One of TrustTier ('NEW' | 'LOW' |
  // 'MEDIUM' | 'HIGH' | 'VERY_HIGH'), null = use the computed tier. Never
  // read by any automatic accounting logic — display/explainability only.
  trustOverride                 String?
  phoneNormalizationNeedsReview Boolean   @default(false)
  createdAt                     DateTime  @default(now())
  deletedAt                     DateTime?
  deletedBy                     String?
  deleteNote                    String?

  // Relations
  shop                 Shop                  @relation(fields: [shopId], references: [id])
  sales                Sale[]
  nasiya               Nasiya[]
  olibSotdimOperations OlibSotdimOperation[]

  @@unique([id, shopId])
  // ACTIVE-ONLY CUSTOMER PHONE UNIQUENESS (per shop) is enforced by a raw-SQL
  // PARTIAL UNIQUE index `Customer_shopId_normalizedPhone_active_key ... WHERE
  // "deletedAt" IS NULL AND "normalizedPhone" IS NOT NULL` created in
  // prisma/migrations/202607020002_integrity_return_ledger. Prisma cannot
  // express partial uniques, so this is only a plain index here. DO NOT run
  // `prisma db push` / `prisma migrate dev` — they would drop it. Use
  // `migrate deploy` only.
  @@index([shopId])
  @@index([shopId, normalizedPhone])
  @@index([shopId, passportIdentifierHash])
}

// ---------------------------------------------------------------------------
// Sale
// ---------------------------------------------------------------------------

model Sale {
  id                             String                         @id @default(cuid())
  shopId                         String
  deviceId                       String
  customerId                     String
  salePrice                      Decimal                        @db.Decimal(12, 2)
  // Null only when no money was received at creation ("Pay later", paid now
  // = 0). Every real SalePayment continues to require its own method.
  paymentMethod                  PaymentMethod?
  paidFully                      Boolean                        @default(true)
  amountPaid                     Decimal                        @db.Decimal(12, 2)
  remainingAmount                Decimal                        @default(0) @db.Decimal(12, 2)
  dueDate                        DateTime?
  reminderEnabled                Boolean                        @default(false)
  // Same early-reminder mechanism as Nasiya, for a later-payment cash sale's
  // single dueDate.
  earlyReminderEnabled           Boolean                        @default(false)
  earlyReminderDays              Int?
  note                           String?
  // Informational only — the shop's selected display currency + USD/UZS rate
  // at the moment this sale was created. Never used in debt/report math
  // (salePrice/amountPaid/remainingAmount stay the UZS ledger source of
  // truth); purely lets the UI note "this deal was made in USD" even after
  // the shop later switches preferredCurrency. Null for older rows (assume
  // UZS, no rate to show) — see docs/currency-accounting-model.md.
  creationCurrency               CurrencyCode?
  creationExchangeRate           Decimal?                       @db.Decimal(12, 4)
  // --- Native contract-currency ledger (source of truth for debt) ------------
  // Additive, alongside the untouched legacy UZS fields above (kept exactly
  // as-is for report/profit/Telegram compatibility). contractCurrency is
  // decided once at creation and immutable forever. Sale has no
  // schedule/allocation like Nasiya — a single-payment/remaining-balance
  // ledger — so no per-schedule contract mirror is needed. See
  // docs/currency-accounting-model.md (Phase 10: schema-only for this pass;
  // display/reminders/Telegram remain on the legacy UZS ledger, documented
  // as deferred).
  contractCurrency               CurrencyCode                   @default(UZS)
  contractExchangeRateAtCreation Decimal?                       @db.Decimal(12, 4)
  contractSalePrice              Decimal                        @default(0) @db.Decimal(12, 2)
  contractAmountPaid             Decimal                        @default(0) @db.Decimal(12, 2)
  contractRemainingAmount        Decimal                        @default(0) @db.Decimal(12, 2)
  // Payment-basis profit ledger. Cost/margin are frozen in the contract's
  // native currency and paid accumulators advance only when money is received.
  contractCostBasisAmount        Decimal                        @default(0) @db.Decimal(12, 2)
  contractMarginAmount           Decimal                        @default(0) @db.Decimal(12, 2)
  contractPrincipalPaidAmount    Decimal                        @default(0) @db.Decimal(12, 2)
  contractMarginPaidAmount       Decimal                        @default(0) @db.Decimal(12, 2)
  accountingReconstructionStatus AccountingReconstructionStatus @default(PENDING)
  accountingReconstructionReason String?
  accountingReconstructedAt      DateTime?
  createdAt                      DateTime                       @default(now())
  createdBy                      String
  creationIdempotencyKey         String?
  creationCommandHash            String?
  // A physical return closes the operational debt without deleting or
  // rewriting the original contract. The immutable DeviceReturn records the
  // financial reversal in the return period.
  returnedAt                     DateTime?
  returnedBy                     String?
  deletedAt                      DateTime?
  deletedBy                      String?
  deleteNote                     String?

  // Relations
  shop                Shop                   @relation(fields: [shopId], references: [id])
  device              Device                 @relation(fields: [deviceId], references: [id])
  customer            Customer               @relation(fields: [customerId], references: [id])
  payments            SalePayment[]
  returns             DeviceReturn[]
  supplierPayable     SupplierPayable?
  olibSotdimOperation OlibSotdimOperation?
  profitReversals     ReturnProfitReversal[]

  @@unique([id, shopId])
  @@unique([shopId, creationIdempotencyKey])
  @@index([shopId])
  @@index([customerId])
  @@index([deviceId])
  @@index([shopId, paidFully, dueDate])
  // Cross-shop cron scan (overdue sale reminders): filters by paidFully + due
  // date with no shopId, so a shopId-leading index cannot serve it.
  @@index([paidFully, dueDate])
}

// ---------------------------------------------------------------------------
// SalePayment
// ---------------------------------------------------------------------------

model SalePayment {
  id                              String        @id @default(cuid())
  saleId                          String
  shopId                          String
  amount                          Decimal       @db.Decimal(12, 2)
  paymentMethod                   PaymentMethod
  paidAt                          DateTime      @default(now())
  note                            String?
  idempotencyKey                  String?
  // What the customer actually entered/paid, preserved for historical display
  // — never recomputed from a later exchange rate. `amount` above is a
  // legacy UZS reporting snapshot only; `appliedAmountInContractCurrency`
  // and the schedule ledger are the authoritative debt evidence. The quote
  // fields retain exactly what was known at receipt time. Null for older rows
  // or UZS payments where no conversion was needed.
  paymentInputAmount              Decimal?      @db.Decimal(12, 2)
  paymentInputCurrency            CurrencyCode?
  paymentExchangeRate             Decimal?      @db.Decimal(12, 4)
  // The payment amount actually applied to the sale's contract-currency debt
  // — frozen forever, never recomputed. `amount` above already serves as the
  // UZS-applied snapshot (unchanged role). See docs/currency-accounting-model.md.
  appliedAmountInContractCurrency Decimal?      @db.Decimal(12, 2)
  // Split-payment breakdown — e.g. half cash, half card. `[{ method:
  // PaymentMethod, amount: number }]`, amounts in the same currency as
  // `paymentInputAmount`/`amount` above, summing to the payment total.
  // `paymentMethod` above stays populated (a representative single value —
  // "CASH" for an all-cash payment, "OTHER" when genuinely mixed) so every
  // existing single-method reader keeps working unchanged; this field is
  // purely additive display/audit detail. Null for a normal single-method
  // payment (the common case).
  paymentBreakdown                Json?
  // Durable replay metadata: distinguishes a server-assigned payment time
  // from an explicitly supplied one and freezes the requested next due date.
  paymentDateExplicit             Boolean       @default(false)
  requestedNextDueDate            DateTime?
  // Frozen payment-date component split. UZS fields are the reporting facts;
  // contract fields preserve the native-currency allocation exactly.
  contractPrincipalAmount         Decimal       @default(0) @db.Decimal(12, 2)
  contractMarginAmount            Decimal       @default(0) @db.Decimal(12, 2)
  principalAmountUzs              Decimal       @default(0) @db.Decimal(12, 2)
  marginAmountUzs                 Decimal       @default(0) @db.Decimal(12, 2)
  createdBy                       String
  createdAt                       DateTime      @default(now())
  deletedAt                       DateTime?
  deletedBy                       String?
  deleteNote                      String?

  // Relations
  sale              Sale                     @relation(fields: [saleId], references: [id])
  returnAllocations ReturnRefundAllocation[]

  @@unique([shopId, idempotencyKey])
  @@unique([id, shopId])
  @@index([saleId])
  @@index([shopId])
  @@index([paidAt])
}

// ---------------------------------------------------------------------------
// SupplierPayable — "Olib-sotdim": money WE owe an external supplier for a
// device we sourced from them and sold straight to our customer. Tracked
// separately from Sale.remainingAmount (customer owes us) — never mixed.
// ---------------------------------------------------------------------------

enum SupplierPayableStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
  OVERDUE
}

enum SupplierPayableOrigin {
  OLIB_SOTDIM
  DEVICE_PURCHASE
}

enum OlibSotdimDealType {
  SALE
  NASIYA
}

// One durable identity for an Olib-sotdim operation, independent of whether
// the customer outcome is an ordinary Sale or a Nasiya contract.
model OlibSotdimOperation {
  id                     String             @id @default(cuid())
  shopId                 String
  deviceId               String             @unique
  customerId             String
  dealType               OlibSotdimDealType
  saleId                 String?            @unique
  nasiyaId               String?            @unique
  createdBy              String
  creationIdempotencyKey String
  creationCommandHash    String
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  shop            Shop             @relation(fields: [shopId], references: [id])
  device          Device           @relation(fields: [deviceId], references: [id])
  customer        Customer         @relation(fields: [customerId], references: [id])
  sale            Sale?            @relation(fields: [saleId], references: [id])
  nasiya          Nasiya?          @relation(fields: [nasiyaId], references: [id])
  supplierPayable SupplierPayable?

  @@unique([id, shopId])
  @@unique([shopId, creationIdempotencyKey])
  @@index([shopId, createdAt, id])
}

model SupplierPayable {
  id                             String                @id @default(cuid())
  shopId                         String
  deviceId                       String
  saleId                         String?               @unique
  olibSotdimOperationId          String?               @unique
  supplierId                     String?
  origin                         SupplierPayableOrigin @default(OLIB_SOTDIM)
  // Free-text — an ad-hoc bazaar contact, not the formal Supplier model (which
  // represents a registered long-term inventory supplier tied to Device.supplierId).
  supplierName                   String
  supplierPhone                  String
  supplierLocation               String?
  supplierNote                   String?
  amount                         Decimal               @db.Decimal(12, 2)
  // Native contract-currency ledger — the currency this payable was actually
  // agreed in, frozen at creation. `amount` above stays the UZS ledger
  // (unchanged). Paying a supplier payable is a binary PENDING->PAID status
  // flip with no partial-payment amount entry, so no allocation/payment-time
  // conversion is needed here (unlike Nasiya). See docs/currency-accounting-model.md.
  contractCurrency               CurrencyCode          @default(UZS)
  contractExchangeRateAtCreation Decimal?              @db.Decimal(12, 4)
  contractAmount                 Decimal               @default(0) @db.Decimal(12, 2)
  paidAmount                     Decimal               @default(0) @db.Decimal(12, 2)
  remainingAmount                Decimal               @default(0) @db.Decimal(12, 2)
  contractPaidAmount             Decimal               @default(0) @db.Decimal(12, 2)
  contractRemainingAmount        Decimal               @default(0) @db.Decimal(12, 2)
  ledgerVersion                  Int                   @default(1)
  status                         SupplierPayableStatus @default(PENDING)
  dueDate                        DateTime
  reminderEnabled                Boolean               @default(true)
  earlyReminderEnabled           Boolean               @default(false)
  earlyReminderDays              Int?
  paidAt                         DateTime?
  lastPaymentAt                  DateTime?
  paymentMethod                  PaymentMethod?
  // Split-payment breakdown — see the identical field on SalePayment for the
  // full rationale. Null for a normal single-method payment.
  paymentBreakdown               Json?
  note                           String?
  createdBy                      String
  creationIdempotencyKey         String?
  creationCommandHash            String?
  createdAt                      DateTime              @default(now())
  updatedAt                      DateTime              @updatedAt
  deletedAt                      DateTime?
  deletedBy                      String?
  deleteNote                     String?

  // Relations
  shop                Shop                     @relation(fields: [shopId], references: [id])
  device              Device                   @relation(fields: [deviceId], references: [id])
  sale                Sale?                    @relation(fields: [saleId], references: [id])
  supplier            Supplier?                @relation(fields: [supplierId], references: [id])
  olibSotdimOperation OlibSotdimOperation?     @relation(fields: [olibSotdimOperationId], references: [id])
  payments            SupplierPayablePayment[]

  @@unique([id, shopId])
  @@unique([shopId, creationIdempotencyKey])
  @@index([shopId])
  @@index([status])
  @@index([supplierId])
  @@index([shopId, status, dueDate])
  // Cross-shop cron scan (supplier payable reminders): filters by status + due
  // date with no shopId, so a shopId-leading index cannot serve it.
  @@index([status, dueDate])
}

// Append-only evidence for every partial, split, or full outgoing supplier
// payment. SupplierPayable totals are a transactionally maintained projection.
model SupplierPayablePayment {
  id                              String        @id @default(cuid())
  shopId                          String
  supplierPayableId               String
  amount                          Decimal       @db.Decimal(12, 2)
  paymentInputAmount              Decimal       @db.Decimal(12, 2)
  paymentInputCurrency            CurrencyCode
  paymentExchangeRate             Decimal?      @db.Decimal(12, 4)
  paymentExchangeRateSource       String?
  paymentExchangeRateEffectiveAt  DateTime?
  paymentExchangeRateFetchedAt    DateTime?
  appliedAmountInContractCurrency Decimal       @db.Decimal(12, 2)
  paymentMethod                   PaymentMethod
  paymentBreakdown                Json?
  paidAt                          DateTime      @default(now())
  note                            String?
  createdBy                       String
  idempotencyKey                  String
  commandHash                     String
  createdAt                       DateTime      @default(now())

  shop    Shop            @relation(fields: [shopId], references: [id])
  payable SupplierPayable @relation(fields: [supplierPayableId], references: [id])

  @@unique([id, shopId])
  @@unique([shopId, idempotencyKey])
  @@index([shopId, supplierPayableId, paidAt, id])
}

// ---------------------------------------------------------------------------
// Nasiya (Instalment plan)
// ---------------------------------------------------------------------------

model Nasiya {
  id                                 String                         @id @default(cuid())
  shopId                             String
  deviceId                           String
  customerId                         String
  // Original agreed device sale price before down payment and nasiya interest.
  totalAmount                        Decimal                        @db.Decimal(12, 2)
  downPayment                        Decimal                        @db.Decimal(12, 2)
  // Debt before interest: totalAmount - downPayment.
  baseRemainingAmount                Decimal                        @default(0) @db.Decimal(12, 2)
  interestPercent                    Decimal                        @default(0) @db.Decimal(6, 2)
  interestAmount                     Decimal                        @default(0) @db.Decimal(12, 2)
  finalNasiyaAmount                  Decimal                        @default(0) @db.Decimal(12, 2)
  remainingAmount                    Decimal                        @db.Decimal(12, 2)
  months                             Int
  monthlyPayment                     Decimal                        @db.Decimal(12, 2)
  startDate                          DateTime
  status                             NasiyaStatus                   @default(ACTIVE)
  // Operational collection state is intentionally separate from the
  // financial contract status above. Archiving or writing off a receivable
  // never rewrites schedules, payments, or native remaining balances.
  resolutionState                    NasiyaResolutionState          @default(ACTIVE)
  resolutionUpdatedAt                DateTime?
  reminderEnabled                    Boolean                        @default(true)
  // "Ertaroq eslatilsinmi?" — an extra reminder N days before each schedule's
  // due date, in addition to the existing due-day reminder. Both respect
  // reminderEnabled; earlyReminderDays is only meaningful when the flag is set.
  earlyReminderEnabled               Boolean                        @default(false)
  earlyReminderDays                  Int?
  note                               String?
  // Informational only — the shop's selected display currency + USD/UZS rate
  // at the moment this nasiya was created. Never used in debt/schedule math
  // (totalAmount/finalNasiyaAmount/remainingAmount stay the UZS ledger
  // source of truth); purely lets the UI note "this deal was made in USD"
  // even after the shop later switches preferredCurrency. Null for older
  // rows — see docs/currency-accounting-model.md.
  creationCurrency                   CurrencyCode?
  creationExchangeRate               Decimal?                       @db.Decimal(12, 4)
  // --- Native contract-currency ledger (source of truth for debt math) -------
  // The legacy UZS fields above (totalAmount, finalNasiyaAmount, remainingAmount,
  // monthlyPayment, etc.) remain exactly as before — a compatibility snapshot
  // frozen at contractExchangeRateAtCreation, kept in lockstep at every
  // mutation, so every existing report/profit/Telegram-creation-message call
  // site keeps working unchanged. NEW logic (schedule/payment/allocation/
  // completion) uses these contract* fields instead. contractCurrency is
  // decided once at creation and is immutable forever — see
  // docs/currency-accounting-model.md.
  contractCurrency                   CurrencyCode                   @default(UZS)
  contractExchangeRateAtCreation     Decimal?                       @db.Decimal(12, 4)
  contractTotalAmount                Decimal                        @default(0) @db.Decimal(12, 2)
  contractDownPayment                Decimal                        @default(0) @db.Decimal(12, 2)
  contractBaseRemainingAmount        Decimal                        @default(0) @db.Decimal(12, 2)
  contractInterestAmount             Decimal                        @default(0) @db.Decimal(12, 2)
  contractFinalAmount                Decimal                        @default(0) @db.Decimal(12, 2)
  contractMonthlyPayment             Decimal                        @default(0) @db.Decimal(12, 2)
  contractRemainingAmount            Decimal                        @default(0) @db.Decimal(12, 2)
  contractPaidAmount                 Decimal                        @default(0) @db.Decimal(12, 2)
  // Profit waived by an audited early-settlement agreement. This is fulfilled
  // debt, never cash and never recognized profit. The legacy UZS mirror stays
  // on the contract's frozen creation-rate basis; NasiyaSettlement separately
  // preserves the settlement-time UZS value used for event reporting.
  interestWaivedAmount               Decimal                        @default(0) @db.Decimal(12, 2)
  contractInterestWaivedAmount       Decimal                        @default(0) @db.Decimal(12, 2)
  // Frozen component budgets for payment-basis monthly recognition.
  contractCostBasisAmount            Decimal                        @default(0) @db.Decimal(12, 2)
  contractMarginAmount               Decimal                        @default(0) @db.Decimal(12, 2)
  contractDownPaymentPrincipalAmount Decimal                        @default(0) @db.Decimal(12, 2)
  contractDownPaymentMarginAmount    Decimal                        @default(0) @db.Decimal(12, 2)
  accountingReconstructionStatus     AccountingReconstructionStatus @default(PENDING)
  accountingReconstructionReason     String?
  accountingReconstructedAt          DateTime?
  createdAt                          DateTime                       @default(now())
  createdBy                          String
  updatedAt                          DateTime                       @updatedAt
  // See Sale.returnedAt. CANCELLED remains the operational terminal status;
  // these fields distinguish a physical return from other cancellations.
  returnedAt                         DateTime?
  returnedBy                         String?
  deletedAt                          DateTime?
  deletedBy                          String?
  deleteNote                         String?

  // --- Imported (pre-Oryx) nasiya bookkeeping ---------------------------------
  // An imported nasiya is EXISTING debt carried over from before the shop used
  // Oryx — NOT a new sale. These fields are informational and MUST be kept out of
  // current-period gross/income/profit (see shop-stats.ts nasiyaSoldThisMonth,
  // which filters isImported=false). alreadyPaidBeforeImport is never turned into
  // a NasiyaPayment row, so it can't be counted as current cash.
  isImported              Boolean   @default(false)
  importSource            String? // MANUAL | EXCEL
  importedAt              DateTime?
  importedById            String?
  originalSaleDate        DateTime?
  originalTotalAmount     Decimal?  @db.Decimal(12, 2)
  alreadyPaidBeforeImport Decimal   @default(0) @db.Decimal(12, 2)
  remainingAtImport       Decimal?  @db.Decimal(12, 2)
  importNote              String?

  // Relations
  shop                  Shop                         @relation(fields: [shopId], references: [id])
  device                Device                       @relation(fields: [deviceId], references: [id])
  customer              Customer                     @relation(fields: [customerId], references: [id])
  schedules             NasiyaSchedule[]
  payments              NasiyaPayment[]
  returns               DeviceReturn[]
  paymentAllocations    NasiyaPaymentAllocation[]
  settlement            NasiyaSettlement?
  settlementAllocations NasiyaSettlementAllocation[]
  profitReversals       ReturnProfitReversal[]
  olibSotdimOperation   OlibSotdimOperation?

  @@unique([id, shopId])
  // Supports the database-enforced schedule/parent currency invariant. The
  // corresponding composite FK is installed by the financial-invariants SQL
  // migration because Prisma cannot express the additional relationship
  // without replacing the existing ergonomic relation.
  @@unique([id, shopId, contractCurrency])
  @@index([shopId])
  @@index([status])
  @@index([deviceId])
  @@index([customerId])
  @@index([shopId, isImported])
  @@index([shopId, resolutionState, status])
}

// ---------------------------------------------------------------------------
// NasiyaSchedule
// ---------------------------------------------------------------------------

model NasiyaSchedule {
  id                           String               @id @default(cuid())
  nasiyaId                     String
  shopId                       String
  monthNumber                  Int
  dueDate                      DateTime
  expectedAmount               Decimal              @db.Decimal(12, 2)
  paidAmount                   Decimal              @default(0) @db.Decimal(12, 2)
  status                       NasiyaScheduleStatus @default(PENDING)
  paidAt                       DateTime?
  paymentMethod                PaymentMethod?
  delayedUntil                 DateTime?
  deferredToNext               Boolean              @default(false)
  note                         String?
  // Native contract-currency mirror of expectedAmount/paidAmount above —
  // copied from the parent Nasiya at creation (immutable, since a nasiya's
  // contractCurrency never changes) so reads here never need to join back to
  // the parent. Source of truth for allocation/completion; expectedAmount/
  // paidAmount stay the UZS compatibility snapshot. See
  // docs/currency-accounting-model.md.
  contractCurrency             CurrencyCode         @default(UZS)
  contractExpectedAmount       Decimal              @default(0) @db.Decimal(12, 2)
  contractPaidAmount           Decimal              @default(0) @db.Decimal(12, 2)
  contractRemainingAmount      Decimal              @default(0) @db.Decimal(12, 2)
  // Exact native-currency split of this instalment. Paid component totals are
  // denormalized from the append-only allocation ledger for set-based expected
  // profit/interest queries; the ledger remains the audit source of truth.
  contractPrincipalAmount      Decimal              @default(0) @db.Decimal(12, 2)
  contractMarginAmount         Decimal              @default(0) @db.Decimal(12, 2)
  contractInterestAmount       Decimal              @default(0) @db.Decimal(12, 2)
  contractPrincipalPaidAmount  Decimal              @default(0) @db.Decimal(12, 2)
  contractMarginPaidAmount     Decimal              @default(0) @db.Decimal(12, 2)
  contractInterestPaidAmount   Decimal              @default(0) @db.Decimal(12, 2)
  interestWaivedAmount         Decimal              @default(0) @db.Decimal(12, 2)
  contractInterestWaivedAmount Decimal              @default(0) @db.Decimal(12, 2)
  createdAt                    DateTime             @default(now())

  // Relations
  nasiya                Nasiya                       @relation(fields: [nasiyaId], references: [id], onDelete: Cascade)
  payments              NasiyaPayment[]
  paymentAllocations    NasiyaPaymentAllocation[]
  settlementAllocations NasiyaSettlementAllocation[]

  @@unique([id, shopId])
  // Lets NasiyaPayment prove that an optional schedule belongs to this exact
  // contract, not merely to another contract in the same shop.
  @@unique([id, shopId, nasiyaId])
  @@index([nasiyaId])
  @@index([shopId])
  @@index([status])
  @@index([shopId, status, dueDate])
  // Cross-shop cron scan (reminders/overdue): filters by status + due date with
  // no shopId, so a shopId-leading index cannot serve it.
  @@index([status, dueDate])
}

// ---------------------------------------------------------------------------
// NasiyaDeferral
// ---------------------------------------------------------------------------

model NasiyaDeferral {
  id               String    @id @default(cuid())
  shopId           String
  nasiyaId         String
  nasiyaScheduleId String
  // The exact effective due date before and after this append-only command.
  // delayedUntil remains as the compatibility value read by schedule queries.
  originalDueDate  DateTime
  newDueDate       DateTime
  delayedUntil     DateTime
  note             String?
  idempotencyKey   String
  createdBy        String
  createdByType    ActorType
  createdAt        DateTime  @default(now())

  @@unique([shopId, idempotencyKey])
  @@index([nasiyaId])
  @@index([nasiyaScheduleId])
  @@index([shopId])
}

// ---------------------------------------------------------------------------
// NasiyaResolutionEvent — immutable archive/write-off/reopen evidence.
//
// The Nasiya row stores only the current operational state. Every transition
// is appended here with the native debt snapshot and its frozen UZS context.
// A REOPEN row points at the event it compensates; history is never edited.
// Tenant composite FKs and immutable triggers live in the SQL migration.
// ---------------------------------------------------------------------------

model NasiyaResolutionEvent {
  id                    String                    @id @default(cuid())
  shopId                String
  nasiyaId              String
  eventType             NasiyaResolutionEventType
  previousState         NasiyaResolutionState
  newState              NasiyaResolutionState
  contractCurrency      CurrencyCode
  nativeRemainingAmount Decimal                   @db.Decimal(14, 2)
  frozenUzsAmount       Decimal                   @db.Decimal(14, 2)
  frozenUsdUzsRate      Decimal                   @db.Decimal(14, 4)
  reason                String
  actorId               String
  actorType             ActorType
  idempotencyKey        String
  reversesEventId       String?
  createdAt             DateTime                  @default(now())

  @@unique([id, shopId, nasiyaId])
  @@unique([shopId, idempotencyKey])
  @@unique([shopId, reversesEventId])
  @@index([shopId, nasiyaId, createdAt])
  @@index([shopId, eventType, createdAt])
  @@index([shopId, newState, createdAt])
}

// ---------------------------------------------------------------------------
// NasiyaPayment
// ---------------------------------------------------------------------------

model NasiyaPayment {
  id                              String         @id @default(cuid())
  nasiyaId                        String
  nasiyaScheduleId                String?
  shopId                          String
  amount                          Decimal        @db.Decimal(12, 2)
  paymentMethod                   PaymentMethod?
  paidAt                          DateTime       @default(now())
  note                            String?
  idempotencyKey                  String?
  // What the customer actually entered/paid, preserved for historical display
  // — never recomputed from a later exchange rate. `amount` above (UZS)
  // remains the authoritative applied-to-debt figure; these three are purely
  // for showing "customer paid $200 at rate 12,500" verbatim later, even
  // after the shop's rate or preferredCurrency has since changed. Null for
  // older rows / UZS payments with no conversion involved.
  paymentInputAmount              Decimal?       @db.Decimal(12, 2)
  paymentInputCurrency            CurrencyCode?
  paymentExchangeRate             Decimal?       @db.Decimal(12, 4)
  // A concrete provider (`CBU`/`MANUAL`) is retained for new receipts;
  // `RECORDED_FROZEN` means an older row has a rate but no recoverable
  // provider metadata. `UNAVAILABLE_SAME_CURRENCY` records that native debt
  // was accepted without inventing an FX rate; the UZS compatibility snapshot
  // may then use the contract-creation fallback.
  paymentExchangeRateSource       String?
  paymentExchangeRateEffectiveAt  DateTime?
  paymentExchangeRateFetchedAt    DateTime?
  // The payment amount actually applied to the nasiya's contract-currency
  // debt (contractPaidAmount/contractRemainingAmount on Nasiya/NasiyaSchedule)
  // — frozen forever, never recomputed. `amount` above already serves as the
  // UZS-applied snapshot (unchanged role). Null for payments recorded before
  // this field existed. See docs/currency-accounting-model.md.
  appliedAmountInContractCurrency Decimal?       @db.Decimal(12, 2)
  // Split-payment breakdown — see the identical field on SalePayment for the
  // full rationale. Null for a normal single-method payment.
  paymentBreakdown                Json?
  createdBy                       String
  createdAt                       DateTime       @default(now())
  deletedAt                       DateTime?
  deletedBy                       String?
  deleteNote                      String?

  // Relations
  nasiya            Nasiya                    @relation(fields: [nasiyaId], references: [id])
  schedule          NasiyaSchedule?           @relation(fields: [nasiyaScheduleId], references: [id])
  returnAllocations ReturnRefundAllocation[]
  allocations       NasiyaPaymentAllocation[]
  settlement        NasiyaSettlement?

  @@unique([shopId, idempotencyKey])
  @@unique([id, shopId])
  @@index([nasiyaId])
  @@index([nasiyaScheduleId])
  @@index([shopId])
  @@index([paidAt])
}

// Append-only allocation facts. One customer payment may span several
// schedules; down payments use a null schedule. Both native contract amounts
// and the exact payment-date UZS reporting snapshot are preserved.
model NasiyaPaymentAllocation {
  id                      String       @id @default(cuid())
  shopId                  String
  nasiyaId                String
  nasiyaPaymentId         String
  nasiyaScheduleId        String?
  sequence                Int
  contractCurrency        CurrencyCode
  contractAmount          Decimal      @db.Decimal(12, 2)
  contractPrincipalAmount Decimal      @db.Decimal(12, 2)
  contractMarginAmount    Decimal      @db.Decimal(12, 2)
  contractInterestAmount  Decimal      @db.Decimal(12, 2)
  amountUzs               Decimal      @db.Decimal(12, 2)
  principalAmountUzs      Decimal      @db.Decimal(12, 2)
  marginAmountUzs         Decimal      @db.Decimal(12, 2)
  interestAmountUzs       Decimal      @db.Decimal(12, 2)
  createdAt               DateTime     @default(now())

  shop     Shop            @relation(fields: [shopId], references: [id])
  nasiya   Nasiya          @relation(fields: [nasiyaId], references: [id])
  payment  NasiyaPayment   @relation(fields: [nasiyaPaymentId], references: [id])
  schedule NasiyaSchedule? @relation(fields: [nasiyaScheduleId], references: [id])

  @@unique([nasiyaPaymentId, sequence])
  @@index([shopId, createdAt])
  @@index([nasiyaId])
  @@index([nasiyaScheduleId])
}

// Immutable evidence for a deliberate early closure. Cash remains recorded in
// NasiyaPayment/NasiyaPaymentAllocation; this header records the business
// agreement and the exact non-cash profit waiver, if any.
model NasiyaSettlement {
  id                           String               @id @default(cuid())
  shopId                       String
  nasiyaId                     String               @unique
  nasiyaPaymentId              String?              @unique
  mode                         NasiyaSettlementMode
  contractCurrency             CurrencyCode
  contractRemainingBefore      Decimal              @db.Decimal(12, 2)
  contractCashReceivedAmount   Decimal              @db.Decimal(12, 2)
  contractInterestWaivedAmount Decimal              @db.Decimal(12, 2)
  contractRemainingAfter       Decimal              @db.Decimal(12, 2)
  cashReceivedAmountUzs        Decimal              @db.Decimal(12, 2)
  interestWaivedAmountUzs      Decimal              @db.Decimal(12, 2)
  frozenUsdUzsRate             Decimal?             @db.Decimal(12, 4)
  frozenUsdUzsRateSource       String?
  frozenUsdUzsRateEffectiveAt  DateTime?
  frozenUsdUzsRateFetchedAt    DateTime?
  settledAt                    DateTime
  reason                       String?
  actorId                      String
  actorType                    ActorType
  idempotencyKey               String
  commandHash                  String
  createdAt                    DateTime             @default(now())

  shop        Shop                         @relation(fields: [shopId], references: [id])
  nasiya      Nasiya                       @relation(fields: [nasiyaId], references: [id])
  payment     NasiyaPayment?               @relation(fields: [nasiyaPaymentId], references: [id])
  allocations NasiyaSettlementAllocation[]

  @@unique([id, shopId, nasiyaId])
  @@unique([shopId, idempotencyKey])
  @@index([shopId, settledAt, id])
  @@index([shopId, mode, settledAt])
}

// Per-schedule immutable settlement evidence. The cash component breakdown is
// still sourced from NasiyaPaymentAllocation; this row proves which remaining
// interest was waived and that every schedule reached zero.
model NasiyaSettlementAllocation {
  id                           String       @id @default(cuid())
  shopId                       String
  nasiyaId                     String
  nasiyaSettlementId           String
  nasiyaScheduleId             String
  sequence                     Int
  contractCurrency             CurrencyCode
  contractRemainingBefore      Decimal      @db.Decimal(12, 2)
  contractCashAmount           Decimal      @db.Decimal(12, 2)
  contractInterestWaivedAmount Decimal      @db.Decimal(12, 2)
  contractRemainingAfter       Decimal      @db.Decimal(12, 2)
  cashAmountUzs                Decimal      @db.Decimal(12, 2)
  interestWaivedAmountUzs      Decimal      @db.Decimal(12, 2)
  createdAt                    DateTime     @default(now())

  shop       Shop             @relation(fields: [shopId], references: [id])
  nasiya     Nasiya           @relation(fields: [nasiyaId], references: [id])
  settlement NasiyaSettlement @relation(fields: [nasiyaSettlementId], references: [id])
  schedule   NasiyaSchedule   @relation(fields: [nasiyaScheduleId], references: [id])

  @@unique([nasiyaSettlementId, sequence])
  @@unique([nasiyaSettlementId, nasiyaScheduleId])
  @@index([shopId, createdAt])
  @@index([nasiyaId])
  @@index([nasiyaScheduleId])
}

// ---------------------------------------------------------------------------
// DeviceReturn
// ---------------------------------------------------------------------------

model DeviceReturn {
  id                            String         @id @default(cuid())
  shopId                        String
  deviceId                      String
  saleId                        String?
  nasiyaId                      String?
  // One key identifies one physical-sale cycle. Replaying a lost HTTP
  // response returns the same immutable event instead of duplicating it.
  idempotencyKey                String
  // Version 1 is reserved for historic/compatibility-window rows created by
  // the pre-ledger application. Every new writer must explicitly store 2.
  ledgerVersion                 Int
  refundAmount                  Decimal        @default(0) @db.Decimal(12, 2)
  // Frozen native refund entry. `refundAmount` remains the UZS accounting
  // snapshot for compatibility; these fields preserve exactly what the user
  // entered so historic USD refunds never use a later exchange rate.
  refundInputAmount             Decimal?       @db.Decimal(12, 2)
  refundInputCurrency           CurrencyCode?
  refundExchangeRateAtCreation  Decimal?       @db.Decimal(12, 4)
  refundExchangeRateSource      String?
  refundExchangeRateEffectiveAt DateTime?
  refundExchangeRateFetchedAt   DateTime?
  refundMethod                  PaymentMethod?
  // Contract-native disposition snapshot. These amounts never use a later
  // exchange rate and make refunds, retained value, and cancelled debt
  // independently auditable.
  contractCurrency              CurrencyCode   @default(UZS)
  contractAmount                Decimal        @default(0) @db.Decimal(12, 2)
  contractReceiptsAtReturn      Decimal        @default(0) @db.Decimal(12, 2)
  contractRefundAmount          Decimal        @default(0) @db.Decimal(12, 2)
  contractRetainedAmount        Decimal        @default(0) @db.Decimal(12, 2)
  contractCancelledDebt         Decimal        @default(0) @db.Decimal(12, 2)
  // Return-period accounting entries in the UZS reporting ledger. The
  // original-period Sale/Nasiya is preserved unchanged.
  revenueReversalAmountUzs      Decimal        @default(0) @db.Decimal(12, 2)
  interestReversalAmountUzs     Decimal        @default(0) @db.Decimal(12, 2)
  inventoryCostRecoveryUzs      Decimal        @default(0) @db.Decimal(12, 2)
  // Signed UZS net retained cash. It may be negative when a later-rate
  // cross-currency refund creates a real FX loss.
  retainedValueAmountUzs        Decimal        @default(0) @db.Decimal(12, 2)
  note                          String
  createdBy                     String
  createdAt                     DateTime       @default(now())

  // Relations
  shop              Shop                     @relation(fields: [shopId], references: [id])
  device            Device                   @relation(fields: [deviceId], references: [id])
  sale              Sale?                    @relation(fields: [saleId], references: [id])
  nasiya            Nasiya?                  @relation(fields: [nasiyaId], references: [id])
  refundAllocations ReturnRefundAllocation[]
  profitReversal    ReturnProfitReversal?

  @@unique([shopId, idempotencyKey])
  @@unique([id, shopId])
  @@index([shopId])
  @@index([deviceId])
  @@index([saleId])
  @@index([nasiyaId])
  @@index([createdAt])
}

// Return-period reversal of profit that had actually been recognized from
// receipts. It intentionally does not reuse DeviceReturn.interestReversal...
// because that immutable legacy field contains full-contract accrual values.
model ReturnProfitReversal {
  id                          String   @id @default(cuid())
  shopId                      String
  deviceReturnId              String   @unique
  saleId                      String?
  nasiyaId                    String?
  recognizedMarginAmountUzs   Decimal  @default(0) @db.Decimal(12, 2)
  recognizedInterestAmountUzs Decimal  @default(0) @db.Decimal(12, 2)
  createdAt                   DateTime @default(now())

  shop         Shop         @relation(fields: [shopId], references: [id])
  deviceReturn DeviceReturn @relation(fields: [deviceReturnId], references: [id])
  sale         Sale?        @relation(fields: [saleId], references: [id])
  nasiya       Nasiya?      @relation(fields: [nasiyaId], references: [id])

  @@index([shopId, createdAt])
  @@index([saleId])
  @@index([nasiyaId])
}

// Every non-zero refund is allocated back to immutable receipt rows. Exactly
// one payment parent is required by a PostgreSQL CHECK constraint in the
// migration because Prisma cannot express that XOR relationship.
model ReturnRefundAllocation {
  id                  String         @id @default(cuid())
  shopId              String
  deviceReturnId      String
  salePaymentId       String?
  nasiyaPaymentId     String?
  // Historic receipt method is optional and independent from refundMethod.
  sourcePaymentMethod PaymentMethod?
  refundMethod        PaymentMethod
  contractCurrency    CurrencyCode
  contractAmount      Decimal        @db.Decimal(12, 2)
  amountUzs           Decimal        @db.Decimal(12, 2)
  createdAt           DateTime       @default(now())

  deviceReturn  DeviceReturn   @relation(fields: [deviceReturnId], references: [id])
  salePayment   SalePayment?   @relation(fields: [salePaymentId], references: [id])
  nasiyaPayment NasiyaPayment? @relation(fields: [nasiyaPaymentId], references: [id])

  @@index([shopId])
  @@index([deviceReturnId])
  @@index([salePaymentId])
  @@index([nasiyaPaymentId])
}

// ---------------------------------------------------------------------------
// Notification
// ---------------------------------------------------------------------------

model Notification {
  id                         String             @id @default(cuid())
  shopId                     String
  dedupeKey                  String?            @unique
  type                       String
  message                    String
  telegramId                 String
  recipientShopAdminId       String?
  status                     NotificationStatus @default(PENDING)
  scheduledAt                DateTime
  sentAt                     DateTime?
  attemptCount               Int                @default(0)
  lastAttemptAt              DateTime?
  nextAttemptAt              DateTime?
  lastError                  String?
  // Safe lifecycle marker consumed by the bounded Tizim projection. The
  // notification type supplies event context; no message or Telegram ID is
  // copied into operational warning metadata.
  recipientUnavailableReason String?
  cancelledAt                DateTime?
  relatedId                  String?
  relatedType                String?
  // Ordered, tenant-validated device-image keys captured on the first send
  // attempt. Progress is stored per position so a later chunk can be retried
  // without duplicating media Telegram already accepted.
  mediaKeys                  String[]           @default([])
  mediaSentPositions         Int[]              @default([])
  mediaSnapshotAt            DateTime?
  textSentAt                 DateTime?
  createdAt                  DateTime           @default(now())

  // Relations
  shop      Shop       @relation(fields: [shopId], references: [id])
  recipient ShopAdmin? @relation("NotificationRecipient", fields: [recipientShopAdminId, shopId], references: [id, shopId])

  @@index([shopId])
  @@index([recipientShopAdminId, shopId])
  @@index([status])
  @@index([scheduledAt])
  @@index([nextAttemptAt])
  @@index([status, scheduledAt, nextAttemptAt])
  @@index([status, cancelledAt(sort: Desc), id(sort: Desc)])
}

// Durable progress for the daily reminder generator. `completedThrough` is an
// exclusive Tashkent-day boundary; an in-progress catch-up window checkpoints
// its phase + keyset cursor after every bounded page. The short lease prevents
// overlapping Vercel/external cron invocations from racing the watermark.
model ReminderGenerationState {
  id               String    @id
  completedThrough DateTime
  windowStart      DateTime?
  windowEnd        DateTime?
  phase            String?
  cursor           String?
  leaseToken       String?
  leaseExpiresAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([leaseExpiresAt])
}

// ---------------------------------------------------------------------------
// Log
// ---------------------------------------------------------------------------

model Log {
  id         String    @id @default(cuid())
  shopId     String?
  actorId    String
  actorType  ActorType
  action     String
  targetType String
  targetId   String
  oldValue   Json?
  newValue   Json?
  note       String?
  requestId  String?
  // Privacy-safe HMAC network fingerprint, not a raw client IP address.
  ipAddress  String?
  createdAt  DateTime  @default(now())

  // Relations (shopId nullable — null means super admin action)
  shop Shop? @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([shopId, createdAt])
}

// ---------------------------------------------------------------------------
// OpsEvent — system health / job / failure telemetry.
//
// This is NOT the business audit `Log` (user/admin actions). OpsEvent records
// infrastructure signals: cron runs, notification processing outcomes, Telegram
// send/webhook failures, migration-guard blocks. `metadata` must stay small and
// MUST NOT contain secrets, full request bodies, or signed private URLs.
// ---------------------------------------------------------------------------

model OpsEvent {
  id              String     @id @default(cuid())
  level           OpsLevel   @default(INFO)
  event           String
  message         String
  shopId          String?
  actorId         String?
  actorType       ActorType?
  entityType      String?
  entityId        String?
  status          String?
  errorCode       String?
  requestId       String?
  metadata        Json?
  dedupeKey       String?    @unique
  occurrenceCount Int        @default(1)
  lastOccurredAt  DateTime   @default(now())
  createdAt       DateTime   @default(now())

  @@index([level])
  @@index([event])
  @@index([createdAt])
  @@index([event, createdAt])
  @@index([level, lastOccurredAt(sort: Desc)])
  @@index([event, lastOccurredAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// ChangeEvent — durable, tenant-scoped incremental synchronization cursor.
//
// Business mutations already write an audit Log in the same PostgreSQL
// transaction. A database trigger added by the corresponding migration turns
// those audit rows into ChangeEvents atomically. The browser consumes only
// authorized canonical DTOs resolved by /api/sync; metadata here deliberately
// contains no customer, device, payment, or authentication payload.
// ---------------------------------------------------------------------------

model ChangeEvent {
  sequence      BigInt   @id @default(autoincrement())
  scopeType     String
  scopeId       String
  domain        String
  entityType    String
  entityId      String
  operation     String
  mutationKind  String
  entityVersion DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([scopeType, scopeId, sequence])
  @@index([scopeType, scopeId, domain, sequence])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// AuthSession — durable server-side session state for explicit revocation and
// role-specific inactivity enforcement. The signed Auth.js JWT remains the
// browser credential; this record is the authoritative live-session check.
// actorId intentionally has no FK because it can reference either actor table.
// ---------------------------------------------------------------------------

model AuthSession {
  id                 String            @id
  actorId            String
  actorType          ActorType
  shopId             String?
  packageVersionId   String?
  sessionVersion     Int
  policy             AuthSessionPolicy @default(IDLE_10_MINUTES)
  lastSeenAt         DateTime          @default(now())
  lastUserActivityAt DateTime          @default(now())
  expiresAt          DateTime
  revokedAt          DateTime?
  createdAt          DateTime          @default(now())

  packageVersion ShopPackageVersion? @relation(fields: [packageVersionId, shopId], references: [id, shopId])

  @@index([actorType, actorId, revokedAt])
  @@index([expiresAt])
  @@index([revokedAt, lastSeenAt])
  @@index([revokedAt, lastUserActivityAt])
  @@index([packageVersionId, shopId])
}
